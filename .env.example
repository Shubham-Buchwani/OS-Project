# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://db_admin:Buchwani1&2@something.bssvnre.mongodb.net/?appName=something

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug

# ── Email (for password reset) ──────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@ossim.app
